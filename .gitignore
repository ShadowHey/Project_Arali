# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#testing-plugins)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-gyp's dependency directory for binding targets (https://github.com/nodejs/node-gyp)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rts2_cache_*/
.minify_cache_/

# c8 coverage
.c8_output

# Temp directories and files
.temp/
.tmp/

# Vite / Build outputs
dist/
dist-ssr/
*.local

# Environment variables (contains sensitive API keys and secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Serverless Webpack service states (https://github.com/serverless-heaven/serverless-webpack)
.webpack/

# Bundler caches
.parcel-cache
.cache
.next
.nuxt
.vuepress/dist
.serverless

# IDEs and Editors
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
